# Normalize all text files to LF in the repo and on checkout. This stops the
# "LF will be replaced by CRLF" warnings on Windows and keeps the Linux Docker
# build (shell scripts, Dockerfile) happy.
* text=auto eol=lf

# Binary assets — never modify
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.webp  binary
*.svg   text eol=lf
*.woff  binary
*.woff2 binary
*.ttf   binary
*.db    binary
