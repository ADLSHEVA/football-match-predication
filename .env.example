# EuroGoal Predictor — Environment Variables
# Copy this file to `.env` and fill in your keys (the .env file is gitignored).
# Every key is OPTIONAL: the app degrades gracefully (seed/demo data, panels
# shown as "not configured") when a key is missing.

# football-data.org — league results + the 2026 World Cup schedule/results.
# Free registration: https://www.football-data.org/
FOOTBALL_DATA_API_KEY=your_key_here

# the-odds-api.com — betting odds + value-bet analysis.
# Free tier (500 req/mo): https://the-odds-api.com/
THE_ODDS_API_KEY=your_key_here

# API-Football (api-sports.io) — head-to-head + lineups/formations.
# Free tier: https://www.api-football.com/
API_FOOTBALL_KEY=your_key_here

# Optional: comma-separated CORS origins. Not needed when the frontend is
# served same-origin (the default deployment). Example:
# CORS_ALLOW_ORIGINS=https://your-app.onrender.com
