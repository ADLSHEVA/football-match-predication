# Keep the build context small and never ship secrets/artifacts.
.git/
.gitignore
.env
.env.*.local
.codegraph/
.claude/

# Rebuilt inside the image
frontend/node_modules/
frontend/dist/

# Python caches / local DB
**/__pycache__/
**/*.pyc
*.db
*.sqlite3
# …but DO include the pre-fitted seed snapshot so the image ships with it
!backend/seed.db
.venv/
venv/

# Misc
.idea/
.vscode/
.DS_Store
Thumbs.db
run.ps1
